{
  "name": "vibecli",
  "version": "0.1.0",
  "description": "Local-first, provider-agnostic software delivery orchestrator.",
  "type": "module",
  "bin": {
    "vibe": "./dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map",
    "!dist/**/__tests__/**",
    "!dist/**/*.test.*",
    "README.md",
    "SECURITY.md",
    "LICENSE",
    "docs/",
    "scripts/prepare-git-install.mjs",
    "scripts/postinstall-git-global.mjs",
    "package.json"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "vibe": "tsx src/index.ts",
    "package-check": "tsx src/index.ts package-check",
    "package-install-check": "tsx src/index.ts package-install-check",
    "prepare": "node scripts/prepare-git-install.mjs",
    "postinstall": "node scripts/postinstall-git-global.mjs",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "commander": "^12.1.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  }
}
